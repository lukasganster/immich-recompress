# Immich Recompress – environment configuration
#
# Copy this file to ".env" (which is git-ignored) and fill in your values:
#   cp .env.example .env
#
# Variables already set in your shell take precedence over this file.

# Immich API key (Account -> API Keys). An admin key is required for the
# user-list endpoint. You can supply a COMMA-SEPARATED list of keys (one per
# user) to browse several users' libraries at once, e.g.:
#   IMMICH_API_KEY=key_for_alice,key_for_bob
IMMICH_API_KEY=

# Base URL of your Immich server (no trailing slash).
IMMICH_URL=http://localhost:2283

# Port the app listens on (host:container in Docker; AirPlay Receiver squats on
# port 5000 on macOS, hence 5050).
PORT=5050

# Listen address for the LOCAL dev server (python backend/server.py) only.
# Defaults to 127.0.0.1 (localhost only) when unset — leave it commented out.
# The app has NO authentication, so only set 0.0.0.0 if you understand the risk
# and have placed it behind an authenticating reverse proxy. (Ignored under
# Docker: gunicorn always binds inside the container; exposure is the port map.)
# HOST=127.0.0.1

# Optional: SQLite job-history location. Defaults to ./immich_recompress.db
# (the Docker image points this at /data so history survives container restarts).
# IMMICH_DB=/data/immich_recompress.db
