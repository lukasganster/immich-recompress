# Keep the build context small and reproducible. The frontend bundle and all
# dependency trees are (re)built inside the image, never copied from the host.

# Python
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/

# Node / Angular — installed and built in the image
node_modules/
frontend/node_modules/
frontend/.angular/
backend/static/

# Local state that must not leak into the image
.env
*.db
*.db-journal
immich_recompress.db

# VCS / editor / OS
.git/
.gitignore
.idea/
.vscode/
.DS_Store
*.log

# Docs / meta not needed at build time
README.md
docker-compose.yml
